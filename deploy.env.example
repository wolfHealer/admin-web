# 复制为 deploy.env 后填写（deploy.env 不会提交 git）
#
# cp deploy.env.example deploy.env

# ECS SSH
DEPLOY_HOST=112.74.103.140
DEPLOY_USER=root
DEPLOY_PORT=22

# 可选：私钥路径，留空则用默认 ~/.ssh/id_rsa
# DEPLOY_SSH_KEY=~/.ssh/id_ed25519

# 1Panel 网站静态目录
DEPLOY_PATH=/www/sites/admin.rarelink.com.cn/index

# 是否在部署前执行 npm run build
RUN_BUILD=1

# rsync 额外参数（一般不用改）
# RSYNC_EXTRA=--dry-run
